# Sultan Defense frontend — ornek env. Kopyala: cp .env.example .env.local
# Backend: sultandefense (Fastify, port 8090, API path /api — v1 YOK).

NEXT_PUBLIC_API_URL=http://localhost:8090/api
NEXT_PUBLIC_SITE_URL=https://www.sultandefense.com
NEXT_PUBLIC_SITE_ID=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
SEO_MONITORING_WEBHOOK_URL=

# Uretim: SITE_URL + API_URL gercek domaine gore. Backend CORS listesinde bu origin (www + apex) olmali.

# Iletisim haritasi (Izmir/Bornova). Iframe src; API anahtari gerekmez.
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps?q=Folkart+Time+Bornova+Izmir&output=embed

# Analytics / Ads (sultandefense hesabi olusunca doldur; bos = devre disi)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_OFFER_CONVERSION_LABEL=XXXXXXXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_ADS_CONTACT_CONVERSION_LABEL=XXXXXXXXXXXXXXX

# Ana sayfa bolum feature flag'leri (varsayilan: blog/news acik, digerleri kapali)
# NEXT_PUBLIC_FEATURE_HOME_REFERENCES=1
# NEXT_PUBLIC_FEATURE_FOOTER_NEWSLETTER=1
# NEXT_PUBLIC_FEATURE_HOME_BLOG=0
# NEXT_PUBLIC_FEATURE_HOME_NEWS=0
